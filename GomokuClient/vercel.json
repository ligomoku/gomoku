{
  "version": 2,
  "framework": "vite",
  "buildCommand": "yarn build",
  "outputDirectory": "packages/gomoku-core/dist",
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "story.gomoku.app"
        }
      ],
      "destination": "/$1"
    },
    {
      "source": "/(.*)",
      "destination": "https://github.com/ligomoku/gomoku",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
